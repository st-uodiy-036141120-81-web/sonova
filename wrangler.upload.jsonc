{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "sonova-upload",
  "main": "supabase/r2-worker.js",
  "compatibility_date": "2026-06-15",
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "sonova-media"
    }
  ],
  "vars": {
    "ALLOWED_ORIGIN": "https://sonova.st-uodiy-036141120-81.workers.dev",
    "PUBLIC_BASE_URL": "https://pub-sonova-media.r2.dev"
  }
}
